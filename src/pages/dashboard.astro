---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { DashboardGridIsland } from '../components/dashboard/DashboardGridIsland';
---

<DashboardLayout title="Dashboard Analytics">
    <div class="max-w-7xl mx-auto space-y-8">
        
        <header>
            <h1 class="text-3xl font-extrabold tracking-tight leading-tight text-gray-900 dark:text-white">
                Analytics Overview
            </h1>
            <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
                Real-time insights and asset distributions.
            </p>
        </header>

        <DashboardGridIsland client:load />

    </div>
</DashboardLayout>