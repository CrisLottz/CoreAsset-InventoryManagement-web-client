---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { AuthProvider } from '../context/AuthContext';
// Importaremos componentes interactivos aquí más adelante
---

<DashboardLayout title="Resumen">
    <AuthProvider client:load>
        {/* Todo el contenido interactivo debe vivir dentro del AuthProvider */}
        <div class="max-w-7xl mx-auto space-y-6">
            
            <header>
                <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">
                    Resumen de Activos
                </h1>
                <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
                    Visión general del inventario en tu jurisdicción asignada.
                </p>
            </header>

            {/* Aquí colocaremos las tarjetas de métricas y tablas */}
            <div class="p-6 bg-white dark:bg-surface-elevated rounded-lg border border-gray-200 dark:border-gray-700">
                <p class="text-gray-500 dark:text-gray-400 text-sm text-center">
                    Cargando métricas del backend...
                </p>
            </div>

        </div>
    </AuthProvider>
</DashboardLayout>