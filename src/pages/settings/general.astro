---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { AppearanceSettingsIsland } from '../../components/settings/AppearanceSettingsIsland';
import { SecuritySettingsIsland } from '../../components/settings/SecuritySettingsIsland';
import { PreferencesSettingsIsland } from '../../components/settings/PreferencesSettingsIsland';
---

<DashboardLayout title="General Configuration">
    <div class="h-full flex flex-col">
        <!-- Header -->
        <header class="flex-none px-6 py-6 border-b border-gray-200 dark:border-gray-700 bg-white dark:bg-surface-elevated">
            <div class="max-w-7xl mx-auto">
                <h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white tracking-tight leading-tight">
                    General Configuration
                </h1>
                <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
                    Manage your personal appearance preferences and account security.
                </p>
            </div>
        </header>

        <!-- Main Content -->
        <main class="flex-1 overflow-y-auto bg-gray-50 dark:bg-surface-base p-6">
            <div class="max-w-7xl mx-auto space-y-6">
                <!-- Preferences Settings -->
                <div class="w-full">
                    <PreferencesSettingsIsland client:load />
                </div>

                <!-- Grid layout for the settings cards -->
                <div class="grid grid-cols-1 xl:grid-cols-12 gap-6">
                    
                    <!-- Appearance Settings (Left/Top) -->
                    <div class="xl:col-span-7">
                        <AppearanceSettingsIsland client:load />
                    </div>

                    <!-- Security Settings (Right/Bottom) -->
                    <div class="xl:col-span-5">
                        <SecuritySettingsIsland client:load />
                    </div>

                </div>
            </div>
        </main>
    </div>
</DashboardLayout>
