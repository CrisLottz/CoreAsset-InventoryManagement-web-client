---
import Layout from '../../layouts/DashboardLayout.astro';
import { ThemeToggle } from '../../components/settings/ThemeToggle.tsx';
---

<Layout title="General Configuration">
    <div class="max-w-4xl mx-auto space-y-8">
        <header class="mb-8">
            <div class="flex items-center gap-4">
                <a href="/dashboard" class="p-2 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-white bg-white dark:bg-surface-elevated border border-gray-200 dark:border-gray-700 rounded shadow-sm transition-colors" aria-label="Back to dashboard">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                </a>
                <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white tracking-tight" style="letter-spacing: -0.02em; line-height: 1.1;">
                    General Configuration
                </h1>
            </div>
            <p class="mt-2 text-sm md:text-base text-gray-600 dark:text-gray-400">
                Manage global settings and personalization options for your CoreAsset instance.
            </p>
        </header>

        <section class="bg-white dark:bg-surface-elevated border border-gray-200 dark:border-gray-700 rounded-lg p-6 shadow-sm">
            <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Interface Preferences</h2>
            <div class="flex items-center justify-between py-4 border-t border-gray-100 dark:border-gray-800">
                <div>
                    <h3 class="text-sm font-bold text-gray-800 dark:text-gray-200">Theme Mode</h3>
                    <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Switch between light and dark mode, or follow your OS preference.</p>
                </div>
                <ThemeToggle client:only="react" />
            </div>
        </section>
    </div>
</Layout>
