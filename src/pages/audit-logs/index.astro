---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { AuditLogViewerIsland } from '../../components/audit/AuditLogViewerIsland';
---

<DashboardLayout title="System Audit Logs">
    <div class="h-full flex flex-col">
        <!-- Header -->
        <header class="flex-none px-6 py-6 border-b border-gray-200 dark:border-gray-700 bg-white dark:bg-surface-elevated">
            <div class="flex items-center justify-between max-w-7xl mx-auto">
                <div>
                    <h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white tracking-tight leading-tight">
                        System Audit Logs
                    </h1>
                    <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
                        Immutable historical record of all actions performed across the platform.
                    </p>
                </div>
            </div>
        </header>

        <!-- Main Content (Island) -->
        <main class="flex-1 overflow-y-auto bg-gray-50 dark:bg-surface-base p-6">
            <div class="max-w-7xl mx-auto h-full">
                <AuditLogViewerIsland client:load />
            </div>
        </main>
    </div>
</DashboardLayout>
