---
import '../styles/global.css';
import { UserMenuIsland } from '../components/auth/UserMenuIsland';

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title} | CoreAsset Panel</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    </head>
    <body class="bg-gray-50 dark:bg-surface-base text-gray-900 dark:text-gray-100 antialiased flex h-screen overflow-hidden">
        
        <aside class="hidden md:flex w-64 flex-col bg-white dark:bg-surface-elevated border-r border-gray-200 dark:border-gray-700 transition-colors duration-200">
            <div class="h-16 flex items-center px-6 border-b border-gray-200 dark:border-gray-700">
                <span class="text-xl font-bold tracking-tight text-primary-600 dark:text-primary-400">CoreAsset</span>
            </div>
            
            <nav class="flex-1 overflow-y-auto py-4 px-3 space-y-1">
                <a href="/dashboard" class="flex items-center px-3 py-2 text-sm font-medium rounded-md bg-primary-50 text-primary-700 dark:bg-gray-800 dark:text-primary-400">
                    Panel Principal
                </a>
                <a href="/inventory" class="flex items-center px-3 py-2 text-sm font-medium rounded-md text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-800">
                    Inventario Activo
                </a>
            </nav>

            <div class="p-4 border-t border-gray-200 dark:border-gray-700">
                 <UserMenuIsland client:load />
            </div>
        </aside>

        <div class="flex-1 flex flex-col h-screen overflow-hidden">
            
            <header class="h-16 bg-white dark:bg-surface-elevated border-b border-gray-200 dark:border-gray-700 flex items-center justify-between px-4 sm:px-6 transition-colors duration-200">
                <div class="flex items-center md:hidden">
                    <button class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
                        Menú
                    </button>
                </div>
                <div class="flex items-center justify-end w-full">
                </div>
            </header>

            <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8">
                <slot />
            </main>
            
        </div>
    </body>
</html>