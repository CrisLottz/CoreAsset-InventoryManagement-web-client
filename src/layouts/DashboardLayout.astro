---
import '../styles/global.css';
import { UserMenuIsland } from '../components/auth/UserMenuIsland';
import { SidebarIsland } from '../components/navigation/SidebarIsland'; // <--- Nueva importación

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title} | CoreAsset Panel</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <script is:inline>
            (function() {
                const theme = localStorage.getItem('theme');
                if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }

                const colorVars = localStorage.getItem('theme_colors');
                if (colorVars) {
                    try {
                        const parsed = JSON.parse(colorVars);
                        for (const [key, value] of Object.entries(parsed)) {
                            document.documentElement.style.setProperty(key, value);
                        }
                    } catch(e) {}
                }
            })();
        </script>
    </head>
    <body class="bg-gray-50 dark:bg-surface-base text-gray-900 dark:text-gray-100 antialiased flex h-screen overflow-hidden">
        
        <div id="mobile-menu-backdrop" class="fixed inset-0 bg-gray-900/50 z-40 hidden md:hidden"></div>
        <aside id="sidebar-menu" class="hidden fixed inset-y-0 left-0 z-50 md:relative md:flex w-64 flex-col bg-white dark:bg-surface-elevated border-r border-gray-200 dark:border-gray-700 transition-colors duration-200">
            <div class="h-16 flex items-center px-6 border-b border-gray-200 dark:border-gray-700">
                <span class="text-xl font-bold tracking-tight text-primary-600 dark:text-primary-400">CoreAsset</span>
            </div>
            
            {/* INYECCIÓN: Componente Reactivo del Sidebar */}
            <SidebarIsland client:load />

            <div class="p-4 border-t border-gray-200 dark:border-gray-700">
                 {/* Reserved for future bottom sidebar elements */}
            </div>
        </aside>

        <div class="flex-1 flex flex-col h-screen overflow-hidden">
            
            <header class="h-16 bg-white dark:bg-surface-elevated border-b border-gray-200 dark:border-gray-700 flex items-center justify-between px-4 sm:px-6 transition-colors duration-200">
                <div class="flex items-center">
                    <button id="mobile-menu-btn" class="p-2 -ml-2 mr-2 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500" aria-label="Toggle menu">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
                    </button>
                </div>
                <div class="flex items-center justify-end w-full space-x-4">
                    <UserMenuIsland client:load />
                </div>
            </header>

            <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8">
                <slot />
            </main>
            
        </div>

        <script>
            const btn = document.getElementById('mobile-menu-btn');
            const sidebar = document.getElementById('sidebar-menu');
            const backdrop = document.getElementById('mobile-menu-backdrop');

            function toggleMenu() {
                sidebar?.classList.toggle('hidden');
                sidebar?.classList.toggle('md:hidden');
                sidebar?.classList.toggle('md:flex');
                
                if (!sidebar?.classList.contains('hidden')) {
                    backdrop?.classList.remove('hidden');
                } else {
                    backdrop?.classList.add('hidden');
                }
            }

            btn?.addEventListener('click', toggleMenu);
            backdrop?.addEventListener('click', toggleMenu);
        </script>
    </body>
</html>